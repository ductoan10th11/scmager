{
  "manifest_version": 3,
  "name": "eWork Assistant",
  "version": "1.0.0",
  "description": "Side panel eWork để xem tổng quan, công việc, duyệt việc và hỗ trợ nhập KPI trên eOffice.",
  "permissions": ["sidePanel", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "eWork Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vanphongdientu.langson.gov.vn/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://vanphongdientu.langson.gov.vn/*"]
    }
  ],
  "host_permissions": [
    "https://vanphongdientu.langson.gov.vn/*",
    "https://ework.naot.me/*"
  ]
}
